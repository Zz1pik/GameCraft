%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 0}
  m_Name: QuestionDatabase
  m_EditorClassIdentifier: Assembly-CSharp::QuestionDatabase
  questions:
  - id: 0
    text: "\u0412\u044B \u0447\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u0441\u043B\u044B\u0448\u0430\u043B
      \u0432\u043E \u0432\u0440\u0435\u043C\u044F \u043A\u0440\u0430\u0436\u0438?"
    truthfulAnswers:
    - "\u042F \u0441\u043B\u044B\u0448\u0430\u043B, \u043A\u0430\u043A \u043A\u0442\u043E-\u0442\u043E
      \u0431\u044B\u0441\u0442\u0440\u043E \u0443\u0431\u0435\u0433\u0430\u043B,
      \u043D\u043E \u043D\u0435 \u0432\u0438\u0434\u0435\u043B, \u043A\u0442\u043E."
    - "\u0411\u044B\u043B \u0441\u0442\u0440\u0430\u043D\u043D\u044B\u0439 \u0448\u0443\u043C,
      \u0431\u0443\u0434\u0442\u043E \u043A\u0442\u043E-\u0442\u043E \u0447\u0442\u043E-\u0442\u043E
      \u0443\u0440\u043E\u043D\u0438\u043B."
    liarAnswers:
    - "\u041D\u0435\u0442, \u044F \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
      \u0441\u043B\u044B\u0448\u0430\u043B, \u0431\u044B\u043B\u043E \u0442\u0438\u0445\u043E."
    - "\u042F \u0441\u043B\u044B\u0448\u0430\u043B \u0447\u0435\u0439-\u0442\u043E
      \u0433\u043E\u043B\u043E\u0441, \u043A\u0430\u0436\u0435\u0442\u0441\u044F,
      \u044D\u0442\u043E \u0431\u044B\u043B random_npc."
    thiefTruthfulAnswers:
    - "\u042F \u0441\u043B\u044B\u0448\u0430\u043B \u0448\u0430\u0433\u0438, \u043D\u043E
      \u043D\u0435 \u0437\u043D\u0430\u044E, \u043A\u0442\u043E \u044D\u0442\u043E
      \u0431\u044B\u043B."
    - "\u0411\u044B\u043B \u0437\u0432\u0443\u043A \u0445\u043B\u043E\u043F\u0430\u044E\u0449\u0435\u0439
      \u0434\u0432\u0435\u0440\u0438, \u043D\u043E \u044F \u043D\u0435 \u0443\u0432\u0435\u0440\u0435\u043D,
      \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u0432\u044F\u0437\u0430\u043D\u043E."
    thiefLiarAnswers:
    - "\u041D\u0435\u0442, \u043D\u0438\u0447\u0435\u0433\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0433\u043E
      \u043D\u0435 \u0441\u043B\u044B\u0448\u0430\u043B."
    - "\u0414\u0430, \u043A\u0442\u043E-\u0442\u043E \u0433\u0440\u043E\u043C\u043A\u043E
      \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B, \u0434\u0443\u043C\u0430\u044E,
      \u044D\u0442\u043E \u0431\u044B\u043B random_npc."
  - id: 1
    text: "\u041A\u0442\u043E, \u043F\u043E-\u0442\u0432\u043E\u0435\u043C\u0443,
      \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E?"
    truthfulAnswers:
    - "random_npc \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u043D\u0435\u043C\u043D\u043E\u0433\u043E
      \u043D\u0430\u043F\u0440\u044F\u0436\u0451\u043D\u043D\u044B\u043C."
    - "\u042F \u043D\u0435 \u0443\u0432\u0435\u0440\u0435\u043D, \u043D\u043E random_npc
      \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u0441\u0442\u0440\u0430\u043D\u043D\u043E."
    liarAnswers:
    - "random_truthful_npc \u0442\u043E\u0447\u043D\u043E \u0447\u0442\u043E-\u0442\u043E
      \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442!"
    - "\u0412\u0441\u0435 \u0432\u0435\u0434\u0443\u0442 \u0441\u0435\u0431\u044F
      \u043D\u043E\u0440\u043C\u0430\u043B\u044C\u043D\u043E, \u043D\u0435 \u0432\u0438\u0436\u0443
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0445."
    thiefTruthfulAnswers:
    - "random_npc \u0432\u0435\u0434\u0451\u0442 \u0441\u0435\u0431\u044F \u043D\u0435\u0440\u0432\u043D\u043E,
      \u043C\u043E\u0436\u0435\u0442, \u043E\u043D \u0447\u0442\u043E-\u0442\u043E
      \u0437\u043D\u0430\u0435\u0442."
    - "random_npc \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u0442\u0438\u0445\u0438\u0439
      \u043F\u043E\u0441\u043B\u0435 \u043A\u0440\u0430\u0436\u0438."
    thiefLiarAnswers:
    - "\u042F \u0434\u0443\u043C\u0430\u044E, random_npc \u0447\u0442\u043E-\u0442\u043E
      \u0441\u043A\u0440\u044B\u0432\u0430\u0435\u0442."
    - "\u0412\u0441\u0435 \u0432\u0435\u0434\u0443\u0442 \u0441\u0435\u0431\u044F
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E,
      \u0441\u043B\u043E\u0436\u043D\u043E \u0441\u043A\u0430\u0437\u0430\u0442\u044C."
  - id: 2
    text: "\u0412\u044B \u0432\u0438\u0434\u0435\u043B, \u043A\u0442\u043E \u0443\u043A\u0440\u0430\u043B?"
    truthfulAnswers:
    - "\u041D\u0435\u0442, \u043D\u043E \u044F \u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A
      thief_npc \u0431\u044B\u0441\u0442\u0440\u043E \u0443\u0445\u043E\u0434\u0438\u043B
      \u043E\u0442\u0442\u0443\u0434\u0430."
    - "\u042F \u043D\u0435 \u0432\u0438\u0434\u0435\u043B, \u043D\u043E \u043A\u0442\u043E-\u0442\u043E
      \u0432\u044B\u0431\u0435\u0436\u0430\u043B \u0438\u0437 \u0437\u0434\u0430\u043D\u0438\u044F."
    liarAnswers:
    - "\u0414\u0430, \u044D\u0442\u043E \u0442\u043E\u0447\u043D\u043E \u0431\u044B\u043B
      random_npc!"
    - "\u042F \u0432\u0438\u0434\u0435\u043B random_npc, \u043D\u043E \u043D\u0435
      \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E \u043E\u043D \u0447\u0442\u043E-\u0442\u043E
      \u0431\u0440\u0430\u043B."
    thiefTruthfulAnswers:
    - "\u041D\u0435\u0442, \u044F \u0431\u044B\u043B \u0432 \u0434\u0440\u0443\u0433\u043E\u043C
      \u043C\u0435\u0441\u0442\u0435 \u0438 \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435 \u0432\u0438\u0434\u0435\u043B."
    - "\u042F \u0432\u0438\u0434\u0435\u043B \u0442\u043E\u043B\u044C\u043A\u043E
      \u0442\u0435\u043D\u044C, \u043D\u0435 \u043C\u043E\u0433\u0443 \u0441\u043A\u0430\u0437\u0430\u0442\u044C,
      \u043A\u0442\u043E \u044D\u0442\u043E \u0431\u044B\u043B."
    thiefLiarAnswers:
    - "\u042F \u0432\u0438\u0434\u0435\u043B random_npc \u0440\u044F\u0434\u043E\u043C,
      \u043C\u043E\u0436\u0435\u0442, \u044D\u0442\u043E \u043E\u043D?"
    - "\u0414\u0430, \u043D\u043E \u0431\u044B\u043B\u043E \u0442\u0435\u043C\u043D\u043E,
      \u044F \u043D\u0435 \u0440\u0430\u0437\u043E\u0431\u0440\u0430\u043B \u043B\u0438\u0446\u043E."
  - id: 3
    text: "\u0415\u0441\u043B\u0438 \u0431\u044B \u0442\u0435\u0431\u044F \u043F\u043E\u043F\u0440\u043E\u0441\u0438\u043B\u0438
      \u043D\u0430\u0439\u0442\u0438 \u0432\u043E\u0440\u0430, \u043A\u043E\u0433\u043E
      \u0431\u044B \u0442\u044B \u0437\u0430\u043F\u043E\u0434\u043E\u0437\u0440\u0438\u043B
      \u043F\u0435\u0440\u0432\u044B\u043C?"
    truthfulAnswers:
    - "\u041D\u0435 \u0437\u043D\u0430\u044E\u2026 \u043D\u043E random_npc \u0431\u044B\u043B
      \u0440\u044F\u0434\u043E\u043C \u0432 \u0442\u043E\u0442 \u043C\u043E\u043C\u0435\u043D\u0442."
    - "random_npc \u0432\u0451\u043B \u0441\u0435\u0431\u044F \u043D\u0435\u043C\u043D\u043E\u0433\u043E
      \u0441\u0442\u0440\u0430\u043D\u043D\u043E \u043F\u043E\u0441\u043B\u0435 \u043A\u0440\u0430\u0436\u0438."
    liarAnswers:
    - "random_npc! \u042F \u0443\u0432\u0435\u0440\u0435\u043D, \u044D\u0442\u043E
      \u043E\u043D!"
    - "\u0412\u0441\u0435 \u043A\u0430\u0436\u0443\u0442\u0441\u044F \u043C\u043D\u0435
      \u043D\u0435\u0432\u0438\u043D\u043E\u0432\u043D\u044B\u043C\u0438, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
      \u044D\u0442\u043E \u0431\u044B\u043B\u043E \u043D\u0435\u0441\u0447\u0430\u0441\u0442\u043D\u043E\u0435
      \u0441\u043E\u0432\u043F\u0430\u0434\u0435\u043D\u0438\u0435."
    thiefTruthfulAnswers:
    - "\u042F \u0431\u044B \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u043B random_npc,
      \u043E\u043D \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B \u043E\u0431\u0435\u0441\u043F\u043E\u043A\u043E\u0435\u043D\u043D\u044B\u043C."
    - "\u0414\u0443\u043C\u0430\u044E, \u044D\u0442\u043E \u043C\u043E\u0433 \u0431\u044B\u0442\u044C
      \u043A\u0442\u043E-\u0442\u043E, \u043A\u043E\u0433\u043E \u043C\u044B \u043D\u0435
      \u043F\u043E\u0434\u043E\u0437\u0440\u0435\u0432\u0430\u0435\u043C."
    thiefLiarAnswers:
    - "\u042F \u0443\u0432\u0435\u0440\u0435\u043D, \u0447\u0442\u043E \u044D\u0442\u043E
      random_truthful_npc!"
    - "\u041D\u0438\u043A\u0442\u043E \u043D\u0435 \u043A\u0430\u0436\u0435\u0442\u0441\u044F
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u043C,
      \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435, \u043E\u0448\u0438\u0431\u043A\u0430."
  - id: 4
    text: "\u0412\u044B \u0432\u0438\u0434\u0435\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E
      \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E\u0435?"
    truthfulAnswers:
    - "\u042F \u0432\u0438\u0434\u0435\u043B, \u043A\u0430\u043A thief_npc \u0431\u044B\u0441\u0442\u0440\u043E
      \u0443\u0448\u0451\u043B \u0432 \u0434\u0440\u0443\u0433\u0443\u044E \u0441\u0442\u043E\u0440\u043E\u043D\u0443."
    - "\u0411\u044B\u043B\u043E \u0441\u0442\u0440\u0430\u043D\u043D\u043E, \u0447\u0442\u043E
      random_npc \u0432\u0434\u0440\u0443\u0433 \u043A\u0443\u0434\u0430-\u0442\u043E
      \u0438\u0441\u0447\u0435\u0437."
    liarAnswers:
    - "random_truthful_npc \u0432\u044B\u0433\u043B\u044F\u0434\u0435\u043B \u043F\u043E\u0434\u043E\u0437\u0440\u0438\u0442\u0435\u043B\u044C\u043D\u043E!"
    - "\u041D\u0435\u0442, \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435\u043E\u0431\u044B\u0447\u043D\u043E\u0433\u043E
      \u043D\u0435 \u0437\u0430\u043C\u0435\u0442\u0438\u043B."
    thiefTruthfulAnswers:
    - "\u041D\u0435\u0442, \u0432\u0441\u0451 \u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C
      \u043E\u0431\u044B\u0447\u043D\u044B\u043C."
    - "\u042F \u0432\u0438\u0434\u0435\u043B \u043A\u043E\u0433\u043E-\u0442\u043E,
      \u043D\u043E \u043D\u0435 \u0443\u0432\u0435\u0440\u0435\u043D, \u043A\u0442\u043E
      \u044D\u0442\u043E \u0431\u044B\u043B."
    thiefLiarAnswers:
    - "\u0414\u0430, random_npc \u044F\u0432\u043D\u043E \u043D\u0435\u0440\u0432\u043D\u0438\u0447\u0430\u043B!"
    - "\u0411\u044B\u043B\u043E \u0442\u0438\u0445\u043E, \u0432\u0441\u0451 \u0432
      \u043F\u043E\u0440\u044F\u0434\u043A\u0435."
  - id: 5
    text: "\u0412\u044B \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B\u0438
      \u0441 \u043A\u0435\u043C-\u0442\u043E \u043F\u0435\u0440\u0435\u0434 \u043A\u0440\u0430\u0436\u0435\u0439?"
    truthfulAnswers:
    - "\u0414\u0430, \u044F \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u0441 random_npc
      \u043C\u0438\u043D\u0443\u0442 \u0437\u0430 \u043F\u044F\u0442\u044C \u0434\u043E
      \u044D\u0442\u043E\u0433\u043E."
    - "\u042F \u0440\u0430\u0437\u0433\u043E\u0432\u0430\u0440\u0438\u0432\u0430\u043B
      \u0441 random_npc, \u043D\u043E \u043D\u0435 \u0434\u0443\u043C\u0430\u044E,
      \u0447\u0442\u043E \u044D\u0442\u043E \u0432\u0430\u0436\u043D\u043E."
    liarAnswers:
    - "\u041D\u0435\u0442, \u044F \u0431\u044B\u043B \u043E\u0434\u0438\u043D."
    - "\u042F \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u0441 random_truthful_npc,
      \u043E\u043D \u0442\u043E\u0436\u0435 \u0447\u0442\u043E-\u0442\u043E \u0437\u043D\u0430\u0435\u0442!"
    thiefTruthfulAnswers:
    - "\u042F \u0431\u043E\u043B\u0442\u0430\u043B \u0441 random_npc, \u043D\u043E
      \u043D\u0435 \u0434\u0443\u043C\u0430\u044E, \u0447\u0442\u043E \u044D\u0442\u043E
      \u0432\u0430\u0436\u043D\u043E."
    - "\u042F \u043D\u0438\u043A\u043E\u0433\u043E \u043D\u0435 \u0432\u0438\u0434\u0435\u043B
      \u043F\u0435\u0440\u0435\u0434 \u044D\u0442\u0438\u043C, \u0431\u044B\u043B
      \u0437\u0430\u043D\u044F\u0442."
    thiefLiarAnswers:
    - "\u0414\u0430, \u044F \u0433\u043E\u0432\u043E\u0440\u0438\u043B \u0441 random_truthful_npc,
      \u043E\u043D \u0447\u0442\u043E-\u0442\u043E \u0437\u043D\u0430\u0435\u0442!"
    - "\u041D\u0435\u0442, \u044F \u0431\u044B\u043B \u0437\u0430\u043D\u044F\u0442
      \u0441\u0432\u043E\u0438\u043C\u0438 \u0434\u0435\u043B\u0430\u043C\u0438."
